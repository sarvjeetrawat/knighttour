<!-- res/drawable/ic_splash_knight.xml -->
<!--
    ═══════════════════════════════════════════════════════════════
    KNIGHT TOUR — SPLASH KNIGHT ICON (Static Vector)
    Used as windowSplashScreenAnimatedIcon on API < 31,
    and as fallback on API 31+ if animated version is unavailable.

    Size: 108×108dp (Android adaptive icon inner area)
    The knight chess piece (♞) rendered as a clean vector path.
    ═══════════════════════════════════════════════════════════════
-->
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Gold knight chess piece — centered in 108×108 viewport -->
    <!-- This is a simplified, geometric chess knight silhouette -->

    <!-- Base/pedestal -->
    <path
        android:fillColor="#C8A84B"
        android:pathData="
            M 30,82 L 78,82 L 74,76 L 34,76 Z
        " />

    <!-- Body stem -->
    <path
        android:fillColor="#C8A84B"
        android:pathData="
            M 36,76 L 40,58 L 68,58 L 72,76 Z
        " />

    <!-- Knight head / horse shape (simplified geometric) -->
    <path
        android:fillColor="#C8A84B"
        android:pathData="
            M 42,58
            L 38,50
            L 36,40
            L 40,30
            L 48,24
            L 60,22
            L 68,26
            L 70,34
            L 66,42
            L 70,50
            L 68,58
            Z
        " />

    <!-- Ear detail -->
    <path
        android:fillColor="#E8C96A"
        android:pathData="
            M 58,22 L 64,14 L 70,20 L 68,26 L 60,22 Z
        " />

    <!-- Eye -->
    <path
        android:fillColor="#050508"
        android:pathData="
            M 61,32 A 3,3 0 1,1 61,31.99 Z
        " />

    <!-- Highlight on eye -->
    <path
        android:fillColor="#E8C96A"
        android:pathData="
            M 62,31 A 1,1 0 1,1 62,30.99 Z
        " />

    <!-- Mouth / nostril detail -->
    <path
        android:fillColor="#0D0D14"
        android:pathData="
            M 44,44 L 48,44 L 47,48 L 43,48 Z
        " />

    <!-- Mane detail line -->
    <path
        android:strokeColor="#E8C96A"
        android:strokeWidth="1.5"
        android:fillColor="@android:color/transparent"
        android:pathData="
            M 52,24 Q 48,34 44,42
        " />

    <!-- Gold shimmer accent line -->
    <path
        android:strokeColor="#E8C96A"
        android:strokeWidth="1"
        android:strokeAlpha="0.5"
        android:fillColor="@android:color/transparent"
        android:pathData="
            M 36,76 L 34,76 L 30,82 L 78,82 L 74,76 L 72,76
        " />

</vector>